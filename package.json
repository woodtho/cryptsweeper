{
  "name": "cryptsweeper",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:run": "npm run build && cap run android",
    "android:build": "npm run android:sync && cap build android",
    "predeploy": "npm version patch --no-git-tag-version && npm run build",
    "deploy": "gh-pages -d dist",
    "preview": "vite preview",
    "test": "node test/smoke.test.mjs",
    "bot": "node src/bot/cli.mjs",
    "balance": "node src/bot/balance.mjs --runs=10"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/app": "^8.1.1",
    "@capacitor/core": "^8.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.2",
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "vite": "^6.0.0"
  }
}
